generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime: Supavisor connection pooler (serverless-safe, port 6543)
  url       = env("DATABASE_URL")
  // Migrations: direct DB connection (port 5432), bypasses PgBouncer
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  admin
  librarian
  staff
  student
}

enum BookStatus {
  AVAILABLE
  BORROWED
  MAINTENANCE
  LOST
  RETIRED
}

enum BorrowStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

enum ReservationStatus {
  ACTIVE
  FULFILLED
  CANCELLED
  EXPIRED
}

model Profile {
  id                   String                @id @db.Uuid
  role                 UserRole              @default(student)
  updated_at           DateTime?             @db.Timestamptz(6)
  created_at           DateTime              @default(now()) @db.Timestamptz(6)
  full_name            String?
  email                String?
  avatar_url           String?
  status               String                @default("active")
  department           String?
  phone                String?
  offline_pins         OfflinePin[]
  offline_sessions     OfflineSession[]
  library_cards        LibraryCard[]
  borrowing_records    BorrowingRecord[]
  processed_borrows    BorrowingRecord[]     @relation("ProcessedBy")
  processed_returns    BorrowingRecord[]     @relation("ReturnedBy")
  processed_renewals   Renewal[]             @relation("RenewedBy")
  reservations         Reservation[]
  audit_logs           AuditLog[]
  deleted_profile_info DeletedProfileInfo?

  @@map("profiles")
}

model RolePermission {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role       UserRole
  module     String
  access     Boolean  @default(false)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  @@unique([role, module])
  @@map("role_permissions")
}

model OfflinePin {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  pin_hash   String
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  expires_at DateTime  @db.Timestamptz(6)
  used_at    DateTime? @db.Timestamptz(6)
  user       Profile   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("offline_pins")
}

model OfflineSession {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String   @db.Uuid
  session_token String   @unique
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  user          Profile  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("offline_sessions")
}

// PHASE 1: Core Policy & Category Management
model SystemSetting {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key          String   @unique
  value        String
  description  String?
  data_type    String   @default("string") // string, number, boolean, json
  updated_by   String   @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @updatedAt @db.Timestamptz(6)

  @@map("system_settings")
}

model Category {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  slug        String   @unique
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @updatedAt @db.Timestamptz(6)
  books       Book[]

  @@map("categories")
}

model Book {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title             String
  author            String
  isbn              String?           @unique
  publisher         String?
  edition           String?
  category_id       String            @db.Uuid
  category          Category          @relation(fields: [category_id], references: [id], onDelete: Restrict)
  tags              String[]
  location          String?           // rack/shelf location
  cover_url         String?
  description       String?
  total_copies      Int               @default(1)
  available_copies  Int               @default(1)
  is_active         Boolean           @default(true)
  created_at        DateTime          @default(now()) @db.Timestamptz(6)
  updated_at        DateTime          @updatedAt @db.Timestamptz(6)
  book_copies       BookCopy[]
  reservations      Reservation[]

  @@index([category_id])
  @@index([is_active])
  @@map("books")
}

model BookCopy {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  book_id           String            @db.Uuid
  qr_code           String            @unique // COPY-{YYYYMMDD}-{seq} format
  status            BookStatus        @default(AVAILABLE)
  condition         String            @default("good") // good, damaged, lost, maintenance
  created_at        DateTime          @default(now()) @db.Timestamptz(6)
  updated_at        DateTime          @updatedAt @db.Timestamptz(6)
  book              Book              @relation(fields: [book_id], references: [id], onDelete: Restrict)
  borrowing_records BorrowingRecord[]

  @@index([book_id])
  @@index([qr_code])
  @@index([status])
  @@map("book_copies")
}

model LibraryCard {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  card_number String   @unique
  status     String   @default("active") // active, suspended, expired
  issued_at  DateTime @default(now()) @db.Timestamptz(6)
  expires_at DateTime @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)
  user       Profile  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id])
  @@index([card_number])
  @@index([status])
  @@map("library_cards")
}

model BorrowingRecord {
  id                  String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String?     @db.Uuid // nullable for GDPR compliance
  user_display_name   String?     // snapshot fallback
  book_copy_id        String      @db.Uuid
  processed_by        String      @db.Uuid
  returned_by         String?     @db.Uuid
  borrowed_at         DateTime    @default(now()) @db.Timestamptz(6)
  due_date            DateTime    @db.Timestamptz(6)
  returned_at         DateTime?   @db.Timestamptz(6)
  renewal_count       Int         @default(0)
  status              BorrowStatus @default(ACTIVE)
  created_at          DateTime    @default(now()) @db.Timestamptz(6)
  updated_at          DateTime    @updatedAt @db.Timestamptz(6)
  user                Profile?    @relation(fields: [user_id], references: [id], onDelete: SetNull)
  book_copy           BookCopy    @relation(fields: [book_copy_id], references: [id], onDelete: Restrict)
  librarian           Profile     @relation("ProcessedBy", fields: [processed_by], references: [id], onDelete: Restrict)
  return_librarian    Profile?    @relation("ReturnedBy", fields: [returned_by], references: [id], onDelete: SetNull)
  renewals            Renewal[]

  @@index([user_id])
  @@index([book_copy_id])
  @@index([status])
  @@index([due_date])
  @@map("borrowing_records")
}

model Renewal {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  borrowing_record_id String  @db.Uuid
  renewed_by        String   @db.Uuid
  renewed_at        DateTime @default(now()) @db.Timestamptz(6)
  new_due_date      DateTime @db.Timestamptz(6)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  borrowing_record  BorrowingRecord @relation(fields: [borrowing_record_id], references: [id], onDelete: Cascade)
  librarian         Profile  @relation("RenewedBy", fields: [renewed_by], references: [id], onDelete: Restrict)

  @@index([borrowing_record_id])
  @@map("renewals")
}

model Reservation {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String   @db.Uuid
  book_id           String   @db.Uuid
  status            ReservationStatus @default(ACTIVE)
  reserved_at       DateTime @default(now()) @db.Timestamptz(6)
  hold_expires_at   DateTime @db.Timestamptz(6) // Calculated from hold_expiry_days setting
  fulfilled_at      DateTime? @db.Timestamptz(6)
  queue_position    Int      // Position in wait queue
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @updatedAt @db.Timestamptz(6)
  user              Profile  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  book              Book     @relation(fields: [book_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([book_id])
  @@index([status])
  @@index([hold_expires_at])
  @@map("reservations")
}

// PHASE 3: Security & Audit
model AuditLog {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  admin_id      String   @db.Uuid
  entity_type   String   // system_setting, category, book, library_card, borrowing_record
  entity_id     String?  @db.Uuid
  action        String   // create, update, delete
  old_value     String?  // JSON stored as text
  new_value     String?  // JSON stored as text
  reason        String?
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  admin         Profile  @relation(fields: [admin_id], references: [id], onDelete: Restrict)

  @@index([admin_id])
  @@index([entity_type])
  @@index([created_at])
  @@map("audit_logs")
}

// PHASE 3: GDPR Compliance
model DeletedProfileInfo {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  original_profile_id   String   @db.Uuid @unique
  profile               Profile  @relation(fields: [original_profile_id], references: [id], onDelete: Cascade)
  anonymized_at         DateTime @default(now()) @db.Timestamptz(6)
  deletion_reason       String?
  retained_borrow_count Int      @default(0)
  retained_fine_count   Int      @default(0)

  @@map("deleted_profile_info")
}
